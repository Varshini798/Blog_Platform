PORT=5000

# When true, no local MongoDB install is required (data is lost when the server stops).
USE_MEMORY_MONGO=true

# Real MongoDB (Atlas or local). Used when USE_MEMORY_MONGO is not true.
# MONGO_URI=mongodb://127.0.0.1:27017/socialpulse

JWT_SECRET=change_this_to_a_long_random_string
CLIENT_URL=http://localhost:5173
ADMIN_EMAIL=admin@example.com

# Optional — image uploads use local /uploads when unset
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
